# Database
DATABASE_URL=postgresql+asyncpg://dashboard:dashboard123@db:5432/dashboard_db

# Security
SECRET_KEY=changeme-production-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=120

# File storage
UPLOAD_DIR=/app/uploads
DEDUP_DIR=/app/dedup_data
MAX_FILE_SIZE=52428800

# Railway auto-sets PORT; for local def default is 8000
PORT=8000
